# ── App ────────────────────────────────────────────────────────────────────────
# URL pública do app — usada por helpers server-side que precisam chamar a própria API
NEXT_PUBLIC_APP_URL="https://seu-dominio.vercel.app"

# ── Auth ───────────────────────────────────────────────────────────────────────
AUTH_SECRET="gere-com-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:3000"

# ── Supabase ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."   # Opcional: ignora RLS no storage

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:SENHA@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:SENHA@host:5432/postgres"

# ── WhatsApp / UZAPI ───────────────────────────────────────────────────────────
# URL base da instância UZAPI (sem barra final)
WHATSAPP_UZAPI_URL="https://sua-instancia.uzapi.com.br"
# Nome da sessão criada no painel UZAPI
WHATSAPP_UZAPI_SESSION="nome-da-sessao"
# Chave de autenticação da sessão (header sessionkey)
WHATSAPP_UZAPI_SESSION_KEY="chave-da-sessao"

# ── Token interno (server-to-server) ──────────────────────────────────────────
# Usado por helpers server-side que chamam POST /api/whatsapp/send sem sessão de usuário
# Gere com: openssl rand -hex 32
INTERNAL_API_TOKEN="gere-com-openssl-rand-hex-32"

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"

# ── Banco do Brasil ────────────────────────────────────────────────────────────
BB_ENV="sandbox"
BB_CLIENT_ID="seu_client_id_bb"
BB_CLIENT_SECRET="seu_client_secret_bb"
BB_APP_KEY="seu_app_key_bb"
BB_CONVENIO="1234567"
BB_BOLETO_CARTEIRA="17"
BB_BOLETO_VARIACAO_CARTEIRA="35"
BB_BOLETO_PIX="S"
BB_PIX_KEY="seu_cnpj_ou_chave_pix"
BB_PIX_CERT=""
BB_PIX_KEY_PEM=""

# ── DocuSeal ───────────────────────────────────────────────────────────────────
DOCUSEAL_API_KEY="sua-api-key-docuseal"
DOCUSEAL_WEBHOOK_SECRET=""

# ── Sentry ─────────────────────────────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
