// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  FINANCIAL
  INSPECTOR
  CUSTOMER
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  RENTED
  MAINTENANCE
  UNAVAILABLE
  BLOCKED
  SOLD
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum FineStatus {
  PENDING
  PAID
  APPEAL
  CHARGED_CLIENT
  SETTLED
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(CUSTOMER)

  customer      Customer?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Branch {
  id        String    @id @default(cuid())
  name      String
  address   String
  city      String
  state     String
  phone     String?
  email     String?
  active    Boolean   @default(true)

  vehicles  Vehicle[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Customer {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id])

  type           String    // PF or PJ
  document       String    @unique // CPF or CNPJ
  cnh            String?   @unique
  cnhExpiration  DateTime?
  phone          String?
  address        String?
  blocked        Boolean   @default(false)
  blockedReason  String?
  score          Int       @default(100)
  notes          String?   @db.Text

  cnhUrl         String?   // URL do arquivo da CNH
  addressProofUrl String?  // URL do comprovante de residência

  reservations   Reservation[]
  contracts      RentalContract[]
}

model Vehicle {
  id           String        @id @default(cuid())
  model        String
  brand        String
  version      String?
  year         Int
  plate        String        @unique
  renavam      String        @unique
  chassi       String        @unique
  color        String
  km           Int           @default(0)
  fuelType     String
  transmission String
  doors        Int           @default(4)
  seats        Int           @default(5)
  status       VehicleStatus @default(AVAILABLE)
  photos       String[]

  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])

  branchId     String?
  branch       Branch?       @relation(fields: [branchId], references: [id])

  reservations Reservation[]
  maintenances Maintenance[]
  fines        Fine[]
  inspections  Inspection[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Category {
  id           String    @id @default(cuid())
  name         String    @unique
  dailyRate    Decimal   @db.Decimal(10, 2)
  weeklyRate   Decimal?  @db.Decimal(10, 2)
  monthlyRate  Decimal?  @db.Decimal(10, 2)
  depositValue Decimal   @db.Decimal(10, 2)

  vehicles     Vehicle[]
}

model Reservation {
  id               String            @id @default(cuid())
  startDate        DateTime
  endDate          DateTime
  actualReturnDate DateTime?
  status           ReservationStatus @default(PENDING)
  totalValue       Decimal           @db.Decimal(10, 2)
  depositValue     Decimal?          @db.Decimal(10, 2)
  extraCharges     Decimal?          @db.Decimal(10, 2)
  notes            String?           @db.Text

  customerId       String
  customer         Customer          @relation(fields: [customerId], references: [id])

  vehicleId        String
  vehicle          Vehicle           @relation(fields: [vehicleId], references: [id])

  contract         RentalContract?
  payments         Payment[]
  fines            Fine[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model RentalContract {
  id               String      @id @default(cuid())
  number           String      @unique
  terms            String      @db.Text
  digitalSignature String?     @db.Text
  signedAt         DateTime?
  pdfUrl           String?

  // DocuSeal integration
  docusealSubmissionId  String?
  docusealSubmitterSlug String?

  reservationId    String      @unique
  reservation      Reservation @relation(fields: [reservationId], references: [id])

  customerId       String
  customer         Customer    @relation(fields: [customerId], references: [id])

  inspections      Inspection[]

  createdAt        DateTime    @default(now())
}

model Inspection {
  id            String   @id @default(cuid())
  type          String   // DEPARTURE or RETURN
  km            Int
  fuelLevel     Int      // 0-100 percentage
  observations  String?  @db.Text
  photos        String[]

  // Checklist
  tiresOk       Boolean  @default(true)
  lightsOk      Boolean  @default(true)
  wiperOk       Boolean  @default(true)
  windowsOk     Boolean  @default(true)
  bodyOk        Boolean  @default(true)
  interiorOk    Boolean  @default(true)
  documentsOk   Boolean  @default(true)
  spareTireOk   Boolean  @default(true)
  jackOk        Boolean  @default(true)

  vehicleId     String
  vehicle       Vehicle        @relation(fields: [vehicleId], references: [id])

  contractId    String
  contract      RentalContract @relation(fields: [contractId], references: [id])

  inspectorName String
  createdAt     DateTime @default(now())
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(10, 2)
  method        String        // PIX, BOLETO, CREDIT_CARD, DEBIT_CARD, CASH, BANK_TRANSFER
  status        PaymentStatus @default(PENDING)
  txid          String?       @unique
  qrCode        String?       @db.Text  // PIX copia-e-cola / EMV payload
  description   String?

  // BB Boleto fields
  nossoNumero   String?       // BB boleto nosso número (returned by API)
  digitableLine String?       // Linha digitável
  boletoBarCode String?       // Código de barras numérico

  reservationId String
  reservation   Reservation   @relation(fields: [reservationId], references: [id])

  paidAt        DateTime?
  dueDate       DateTime?
  createdAt     DateTime      @default(now())
}

model Fine {
  id              String     @id @default(cuid())
  amount          Decimal    @db.Decimal(10, 2)
  date            DateTime
  infractionCode  String
  description     String
  location        String?
  status          FineStatus @default(PENDING)
  conductorName   String?
  agencyName      String?
  documentUrl     String?
  chargedToClient Boolean    @default(false)
  chargedAmount   Decimal?   @db.Decimal(10, 2)

  photos          String[]

  vehicleId       String
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id])

  reservationId   String?
  reservation     Reservation? @relation(fields: [reservationId], references: [id])

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Maintenance {
  id              String            @id @default(cuid())
  type            String            // PREVENTIVE, CORRECTIVE
  status          MaintenanceStatus @default(SCHEDULED)
  date            DateTime
  completedAt     DateTime?
  kmAtMaintenance Int
  nextServiceKm   Int?
  nextServiceDate DateTime?
  description     String
  cost            Decimal           @db.Decimal(10, 2)
  provider        String?
  notes           String?           @db.Text

  vehicleId       String
  vehicle         Vehicle           @relation(fields: [vehicleId], references: [id])

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

// ── Vendas de Veículos ─────────────────────────────────────────────────────────

enum SaleVehicleStatus {
  AVAILABLE
  RESERVED
  SOLD
}

model SaleVehicle {
  id           String            @id @default(cuid())
  brand        String
  model        String
  version      String?
  year         Int
  plate        String?
  renavam      String?
  chassi       String?
  color        String
  km           Int               @default(0)
  fuelType     String
  transmission String
  doors        Int               @default(4)
  seats        Int               @default(5)
  price        Decimal           @db.Decimal(12, 2)
  description  String?           @db.Text
  features     String[]
  photos       String[]
  status       SaleVehicleStatus @default(AVAILABLE)
  highlighted  Boolean           @default(false)

  leads        SaleLead[]
  contracts    SaleContract[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model SaleLead {
  id        String      @id @default(cuid())
  name      String
  email     String
  phone     String
  document  String?
  address   String?
  message   String?     @db.Text
  status    String      @default("NEW")

  vehicleId String
  vehicle   SaleVehicle @relation(fields: [vehicleId], references: [id])

  contract  SaleContract?

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model SaleContract {
  id               String      @id @default(cuid())
  number           String      @unique
  salePrice        Decimal     @db.Decimal(12, 2)
  paymentMethod    String
  paymentDetails   String?     @db.Text
  terms            String      @db.Text
  digitalSignature String?     @db.Text
  signedAt         DateTime?

  vehicleId        String
  vehicle          SaleVehicle @relation(fields: [vehicleId], references: [id])

  leadId           String      @unique
  lead             SaleLead    @relation(fields: [leadId], references: [id])

  createdAt        DateTime    @default(now())
}
